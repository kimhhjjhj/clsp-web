generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String?
  contractor  String?
  location    String?
  type        String?
  startDate   String?
  ground      Int?
  basement    Int?
  lowrise     Int?
  hasTransfer Boolean  @default(false)
  sitePerim   Float?
  bldgPerim   Float?
  siteArea    Float?
  bldgArea    Float?
  wtBottom    Float?
  waBottom    Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model Task {
  id           String  @id @default(cuid())
  projectId    String
  wbsCode      String?
  name         String
  category     String?
  subcategory  String?
  unit         String?
  quantity     Float?
  productivity String?
  stdDays      String?
  duration     Float
  predecessors String?
  note         String?
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}