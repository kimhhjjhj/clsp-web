generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String?
  contractor  String?
  location    String?
  type        String?
  startDate   String?
  ground      Int?
  basement    Int?
  lowrise     Int?
  hasTransfer Boolean  @default(false)
  sitePerim   Float?
  bldgPerim   Float?
  siteArea     Float?
  bldgArea     Float?
  buildingArea Float?   // 건축면적 (1층 footprint, 터파기·부지정지 기준)
  wtBottom     Float?
  waBottom     Float?
  constructionMethod     String?                // 'bottom_up' | 'full_top_down' | 'semi_top_down' | 'up_up' — null이면 bottom_up 기본
  lastCpmDuration        Int?
  industrySpecific       Json?                  // 유형별 특화 필드 (데이터센터: tier/racks/mwCapacity/cooling 등)
  processMap             Json?                  // { lanes: [], cards: [], links: [] }
  aiCostEstimate         Json?                  // AI 개략 공사비 추정 결과 (trades, summary, notes, 추정 일시)
  productivityAdjustments Json?                 // 공종별 생산성 조정값 [{ taskId, multiplier }] — /bid 저장 시 보존
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  tasks                  Task[]
  risks                  RiskOpportunity[]
  accelerations          ScheduleAcceleration[]
  baselineTasks          BaselineTask[]
  weeklyProgress         WeeklyProgress[]
  dailyReports           DailyReport[]
  productivityProposals  ProductivityProposal[]
}

model Task {
  id           String  @id @default(cuid())
  projectId    String
  wbsCode      String?
  name         String
  category     String?
  subcategory  String?
  unit         String?
  quantity     Float?
  productivity String?
  stdDays      String?
  duration     Float
  predecessors String?
  note         String?
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── 2단계: 프리콘 ──────────────────────────────────────────

model RiskOpportunity {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // "risk" | "opportunity"
  category    String   // 공종 (공통가설/토목/철콘/철골/습식도장/수장/창호판넬/금속기타/기계/전기/소방/조경/장비/기타보험료)
  content     String
  impactType  String   // "schedule" | "cost"
  impactDays  Float?   // 공기영향(일)
  impactCost  Float?   // 원가영향(만원)
  probability Float    // 0~100(%)
  response    String?
  owner       String?
  status      String   @default("identified") // "identified"|"reviewing"|"closed"
  // ── 실무 엑셀 양식 호환 필드 (R&O 리스트 관리) ─────────
  code             String?  // "CV-001", "RC-001", "EL-001" — 공종코드-번호
  rev              Int?     // 리비전 (0, 1, 2…)
  subCategory      String?  // 세부공종 (예: 토공, 골조, 공조, 위생, 장비)
  proposer         String?  // 제안사 (기본 "동양")
  proposedAt       String?  // 제안일자 YYYY-MM-DD
  proposedCost     Float?   // 제안금액 (백만원, 음수=절감)
  confirmedCost    Float?   // 확정금액 (백만원)
  progress         String?  // "진행" | "확정" | "미반영" | "재검토"
  confirmedAt      String?  // 확정일자 YYYY-MM-DD
  expectedAt       String?  // 예정완료일 YYYY-MM-DD
  designApplied    String?  // "Yes" | "No" | "-"
  note             String?  // 비고
  attachments      Json?    // [{ name, size, type, uploadedAt, url }] — 도면·사진 등
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, category])
  @@index([projectId, progress])
}

model ScheduleAcceleration {
  id          String   @id @default(cuid())
  projectId   String
  category    String
  method      String
  days        Float
  costRate    Float    // 비용증가율(%)
  condition   String?
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BaselineTask {
  id           String   @id @default(cuid())
  projectId    String
  mspId        String?
  wbsCode      String?
  name         String
  duration     Float
  start        String?
  finish       String?
  predecessors String?
  level        Int      @default(0)
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── 3단계: 실시공 관리 ────────────────────────────────────

model WeeklyProgress {
  id          String   @id @default(cuid())
  projectId   String
  year        Int
  weekNo      Int
  taskName    String
  category    String?
  plannedRate Float    @default(0)
  actualRate  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id            String   @id @default(cuid())
  projectId     String
  date          String
  weather       String?
  temperature   Float?
  tempMin       Float?
  tempMax       Float?
  workers       Json?
  manpower      Json?
  equipment     String?
  equipmentList Json?
  materialList  Json?
  workToday     Json?
  workTomorrow  Json?
  signers       Json?
  content       String?
  notes         String?
  photos        Json?    // [{ url, caption?, trade?, uploadedAt }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
// ── 생산성 실적 DB (관리자 승인 플로우) ──────────────────────────

model ProductivityProposal {
  id            String    @id @default(cuid())
  projectId     String?
  trade         String
  value         Float
  unit          String    // man/day, mandays/ton, mandays/m3 등
  sampleSize    Int       // 계산에 사용된 활동일 or 항목 수
  source        Json      // 계산 근거 {totalManDays, activeDays, dateRange, ...}
  status        String    @default("pending") // pending | approved | rejected
  reviewerNote  String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([trade])
}

model CompanyStandardProductivity {
  id                String   @id @default(cuid())
  trade             String
  unit              String
  value             Float
  sampleCount       Int      @default(1)
  sourceProposalIds Json     // 제안 ID 배열
  lastUpdated       DateTime @default(now())

  @@unique([trade, unit])
}
