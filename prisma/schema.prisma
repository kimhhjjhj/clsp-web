generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String?
  contractor  String?
  location    String?
  type        String?
  startDate   String?
  ground      Int?
  basement    Int?
  lowrise     Int?
  hasTransfer Boolean  @default(false)
  sitePerim   Float?
  bldgPerim   Float?
  siteArea    Float?
  bldgArea    Float?
  wtBottom    Float?
  waBottom    Float?
  lastCpmDuration        Int?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  tasks                  Task[]
  risks                  RiskOpportunity[]
  accelerations          ScheduleAcceleration[]
  baselineTasks          BaselineTask[]
  weeklyProgress         WeeklyProgress[]
  dailyReports           DailyReport[]
  productivityProposals  ProductivityProposal[]
}

model Task {
  id           String  @id @default(cuid())
  projectId    String
  wbsCode      String?
  name         String
  category     String?
  subcategory  String?
  unit         String?
  quantity     Float?
  productivity String?
  stdDays      String?
  duration     Float
  predecessors String?
  note         String?
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── 2단계: 프리콘 ──────────────────────────────────────────

model RiskOpportunity {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // "risk" | "opportunity"
  category    String   // 공종
  content     String
  impactType  String   // "schedule" | "cost"
  impactDays  Float?   // 공기영향(일)
  impactCost  Float?   // 원가영향(만원)
  probability Float    // 0~100(%)
  response    String?
  owner       String?
  status      String   @default("identified") // "identified"|"reviewing"|"closed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ScheduleAcceleration {
  id          String   @id @default(cuid())
  projectId   String
  category    String
  method      String
  days        Float
  costRate    Float    // 비용증가율(%)
  condition   String?
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BaselineTask {
  id           String   @id @default(cuid())
  projectId    String
  mspId        String?
  wbsCode      String?
  name         String
  duration     Float
  start        String?
  finish       String?
  predecessors String?
  level        Int      @default(0)
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── 3단계: 실시공 관리 ────────────────────────────────────

model WeeklyProgress {
  id          String   @id @default(cuid())
  projectId   String
  year        Int
  weekNo      Int
  taskName    String
  category    String?
  plannedRate Float    @default(0)
  actualRate  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id            String   @id @default(cuid())
  projectId     String
  date          String
  weather       String?
  temperature   Float?
  tempMin       Float?
  tempMax       Float?
  workers       Json?
  manpower      Json?
  equipment     String?
  equipmentList Json?
  materialList  Json?
  workToday     Json?
  workTomorrow  Json?
  signers       Json?
  content       String?
  notes         String?
  photos        Json?    // [{ url, caption?, trade?, uploadedAt }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
// ── 생산성 실적 DB (관리자 승인 플로우) ──────────────────────────

model ProductivityProposal {
  id            String    @id @default(cuid())
  projectId     String?
  trade         String
  value         Float
  unit          String    // man/day, mandays/ton, mandays/m3 등
  sampleSize    Int       // 계산에 사용된 활동일 or 항목 수
  source        Json      // 계산 근거 {totalManDays, activeDays, dateRange, ...}
  status        String    @default("pending") // pending | approved | rejected
  reviewerNote  String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([trade])
}

model CompanyStandardProductivity {
  id                String   @id @default(cuid())
  trade             String
  unit              String
  value             Float
  sampleCount       Int      @default(1)
  sourceProposalIds Json     // 제안 ID 배열
  lastUpdated       DateTime @default(now())

  @@unique([trade, unit])
}
