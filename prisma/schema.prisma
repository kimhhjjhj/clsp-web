generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String?
  contractor  String?
  location    String?
  type        String?
  startDate   String?
  ground      Int?
  basement    Int?
  lowrise     Int?
  hasTransfer Boolean  @default(false)
  sitePerim   Float?
  bldgPerim   Float?
  siteArea     Float?
  bldgArea     Float?
  buildingArea Float?   // 건축면적 (1층 footprint, 터파기·부지정지 기준)
  wtBottom     Float?
  waBottom     Float?
  constructionMethod     String?                // 'bottom_up' | 'full_top_down' | 'semi_top_down' | 'up_up' — null이면 bottom_up 기본
  prdCount               Int?                   // Top-down 공법 앵커 천공 공수 (상봉동 20공 등)
  lastCpmDuration        Int?
  industrySpecific       Json?                  // 유형별 특화 필드 (데이터센터: tier/racks/mwCapacity/cooling 등)
  processMap             Json?                  // { lanes: [], cards: [], links: [] }
  aiCostEstimate         Json?                  // AI 개략 공사비 추정 결과 (trades, summary, notes, 추정 일시)
  productivityAdjustments Json?                 // 공종별 생산성 조정값 [{ taskId, multiplier }] — /bid 저장 시 보존
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  tasks                  Task[]
  risks                  RiskOpportunity[]
  accelerations          ScheduleAcceleration[]
  baselineTasks          BaselineTask[]
  weeklyProgress         WeeklyProgress[]
  dailyReports           DailyReport[]
  productivityProposals  ProductivityProposal[]
  cpmSnapshots           CpmSnapshot[]
  // F18. 자사 회귀식 재학습용 — 준공 실적
  actualCompletionDate String?
  actualDuration       Int?
}

model Task {
  id           String  @id @default(cuid())
  projectId    String
  wbsCode      String?
  name         String
  category     String?
  subcategory  String?
  unit         String?
  quantity     Float?
  productivity String?
  stdDays      String?
  duration     Float
  predecessors String?
  note         String?
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── 2단계: 프리콘 ──────────────────────────────────────────

model RiskOpportunity {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // "risk" | "opportunity"
  category    String   // 공종 (공통가설/토목/철콘/철골/습식도장/수장/창호판넬/금속기타/기계/전기/소방/조경/장비/기타보험료)
  content     String
  impactType  String   // "schedule" | "cost"
  impactDays  Float?   // 공기영향(일)
  impactCost  Float?   // 원가영향(만원)
  probability Float    // 0~100(%)
  response    String?
  owner       String?
  status      String   @default("identified") // "identified"|"reviewing"|"closed"
  // ── 실무 엑셀 양식 호환 필드 (R&O 리스트 관리) ─────────
  code             String?  // "CV-001", "RC-001", "EL-001" — 공종코드-번호
  rev              Int?     // 리비전 (0, 1, 2…)
  subCategory      String?  // 세부공종 (예: 토공, 골조, 공조, 위생, 장비)
  proposer         String?  // 제안사 (기본 "동양")
  proposedAt       String?  // 제안일자 YYYY-MM-DD
  proposedCost     Float?   // 제안금액 (백만원, 음수=절감)
  confirmedCost    Float?   // 확정금액 (백만원)
  progress         String?  // "진행" | "확정" | "미반영" | "재검토"
  confirmedAt      String?  // 확정일자 YYYY-MM-DD
  expectedAt       String?  // 예정완료일 YYYY-MM-DD
  designApplied    String?  // "Yes" | "No" | "-"
  note             String?  // 비고
  attachments      Json?    // [{ name, size, type, uploadedAt, url }] — 도면·사진 등
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, category])
  @@index([projectId, progress])
}

model ScheduleAcceleration {
  id          String   @id @default(cuid())
  projectId   String
  category    String
  method      String
  days        Float
  costRate    Float    // 비용증가율(%)
  condition   String?
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BaselineTask {
  id           String   @id @default(cuid())
  projectId    String
  mspId        String?
  wbsCode      String?
  name         String
  duration     Float
  start        String?
  finish       String?
  predecessors String?
  level        Int      @default(0)
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── 3단계: 실시공 관리 ────────────────────────────────────

model WeeklyProgress {
  id          String   @id @default(cuid())
  projectId   String
  year        Int
  weekNo      Int
  taskName    String
  category    String?
  plannedRate Float    @default(0)
  actualRate  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id            String   @id @default(cuid())
  projectId     String
  date          String
  weather       String?
  temperature   Float?
  tempMin       Float?
  tempMax       Float?
  workers       Json?
  manpower      Json?
  equipment     String?
  equipmentList Json?
  materialList  Json?
  workToday     Json?
  workTomorrow  Json?
  signers       Json?
  content       String?
  notes         String?
  photos        Json?    // [{ url, caption?, trade?, uploadedAt }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
// ── 생산성 실적 DB (관리자 승인 플로우) ──────────────────────────

model ProductivityProposal {
  id            String    @id @default(cuid())
  projectId     String?
  trade         String
  value         Float
  unit          String    // man/day, mandays/ton, mandays/m3 등
  sampleSize    Int       // 계산에 사용된 활동일 or 항목 수
  source        Json      // 계산 근거 {totalManDays, activeDays, dateRange, ...}
  status        String    @default("pending") // pending | approved | rejected
  reviewerNote  String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([trade])
}

model CompanyStandardProductivity {
  id                String   @id @default(cuid())
  trade             String
  unit              String
  value             Float
  sampleCount       Int      @default(1)
  sourceProposalIds Json     // 제안 ID 배열
  lastUpdated       DateTime @default(now())

  @@unique([trade, unit])
}

// ─────────────────────────────────────────────────────────
// F18. Internal Regression Calibration
//   사내 준공 프로젝트(Project.actualDuration)로 공기 회귀식을
//   재학습. 국토부 회귀 vs 자사 회귀를 overlay 표시.
// ─────────────────────────────────────────────────────────
model InternalRegression {
  id            String   @id @default(cuid())
  projectType   String   // 공동주택 | 오피스텔 | 업무 | 학교 | 병원 | 도로 | 교량 | 터널 | all
  coefficients  Json     // { intercept, slope } 또는 { a, b, c } for polynomial
  sampleSize    Int
  rSquared      Float
  trainedAt     DateTime @default(now())
  note          String?

  @@index([projectType, trainedAt])
}

// ─────────────────────────────────────────────────────────
// F8. Scenario Comparator
//   공법·생산성 multiplier·가속 조합을 시나리오로 저장하고 5개까지
//   병렬 비교. params 변경 시 generateWBS+CPM 재실행 결과를 캐싱.
// ─────────────────────────────────────────────────────────
model Scenario {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  params     Json     // { method, multipliers: [{taskId,mult}], accelerations: [{taskId,days}], startDate? }
  result     Json     // { totalDuration, cost?, criticalCount, riskScore?, computedAt }
  baseline   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId, createdAt])
}

// ─────────────────────────────────────────────────────────
// F3. Delay Root-Cause Attribution
//   CpmSnapshot 변동 + DailyReport 비작업일 + ProductivityObservation 편차
//   를 결합해 Task 지연을 원인별(기상·자원·설계·제약·생산성)로 분해 저장.
// ─────────────────────────────────────────────────────────
model DelayAttribution {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  taskName    String?
  periodFrom  String   // YYYY-MM-DD
  periodTo    String
  cause       String   // weather | manpower | material | design-change | constraint | productivity | unknown
  days        Float
  evidence    Json     // { snapshots: [from, to], observationIds: [...], weatherLogIds: [...] }
  computedAt  DateTime @default(now())

  @@index([projectId, cause])
  @@index([projectId, periodFrom])
}

// ─────────────────────────────────────────────────────────
// F4. Productivity Variance Dashboard
//   DailyReport 저장 시 공종별 관측 생산성을 기록하고
//   CompanyStandardProductivity 대비 z-score 계산.
//   임계 초과 누적은 ProductivityProposal 자동 생성 트리거.
// ─────────────────────────────────────────────────────────
model ProductivityObservation {
  id             String   @id @default(cuid())
  projectId      String
  dailyReportId  String?
  trade          String
  date           String   // YYYY-MM-DD
  observedValue  Float    // 관측 생산성 (man/day 또는 mandays/unit)
  unit           String
  quantity       Float?
  manDays        Float?
  zScore         Float?
  status         String   @default("noted") // noted | flagged | proposed
  createdAt      DateTime @default(now())

  @@index([projectId, trade, date])
  @@index([status])
}

// ─────────────────────────────────────────────────────────
// F1. CPM Intelligence Timeline
//   매 이벤트(수동 재계산, 일보 등록, WBS 편집)마다 CPM 결과를 스냅샷으로 영속화.
//   변동 히스토리 시각화 + 두 스냅샷 간 diff 조회.
//   generateWBS·calculateCPM 엔진은 불변. 결과만 저장.
// ─────────────────────────────────────────────────────────
model CpmSnapshot {
  id               String   @id @default(cuid())
  projectId        String
  capturedAt       DateTime @default(now())
  totalDuration    Int
  criticalTaskIds  Json     // 크리티컬 경로에 있는 taskId 배열
  tasksSnapshot    Json     // [{ taskId, name, category, ES, EF, duration, isCritical }]
  triggerEvent     String   // 'manual' | 'daily-report' | 'wbs-edit' | 'initial'
  triggerRef       String?  // 예: dailyReportId, taskId 등 이벤트 연결 식별자
  note             String?
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, capturedAt])
}
