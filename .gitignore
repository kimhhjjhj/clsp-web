# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
public/data/layers.csv
*.csv

# 회사 일보 샘플 (실제 데이터 유출 방지)
/samples/

# 일보 첨부 사진 (유출 방지 + 용량)
/public/uploads/

# R&O 첨부파일 (도면·사진·PDF)
/data/uploads/

# 강의·참고자료 (용량)
*.pdf
/lecture.txt

# 자동 루프 스케줄러 상태
/.claude/scheduled_tasks.lock
